local function tweenPath(waypoints)
    local char, hrp, hum = getCharacter()
    if not hrp or not hum then return end

    pathRunning = true
    hum.AutoRotate = false
    hrp.Anchored = false

    startCorrection()

    task.spawn(function()
        for i = 1, #waypoints do
            if not autoCollectRunning then break end

            local wp = waypoints[i]
            local target = wp.Position

            RaycastParamsGround.FilterDescendantsInstances = {char}
            local result = workspace:Raycast(
                target + Vector3.new(0, 40, 0),
                Vector3.new(0, -500, 0),
                RaycastParamsGround
            )

            if result then
                target = result.Position + Vector3.new(0, 3, 0)
            end

            local toTarget = target - hrp.Position
            local dist = toTarget.Magnitude
            if dist < 0.1 then continue end

            if dist > MAX_STEP then
                target = hrp.Position + toTarget.Unit * MAX_STEP
                dist = MAX_STEP
            end

            local dir = toTarget.Unit
            local duration = math.max(dist / SPEED, 0.05)

            if currentTween then
                currentTween:Cancel()
                currentTween = nil
            end

            local tween = TweenService:Create(
                hrp,
                TweenInfo.new(duration, Enum.EasingStyle.Linear),
                { CFrame = CFrame.new(target, target + dir) }
            )

            currentTween = tween
            local finished = false

            tween.Completed:Connect(function()
                finished = true
            end)

            tween:Play()

            -- idk some fucking nigger shit
            local timeout = tick() + 5
            while not finished and tick() < timeout do
                task.wait()
            end

            if not finished then
                if currentTween then currentTween:Cancel() end
                currentTween = nil
                break
            end

            currentTween = nil
            if not autoCollectRunning then break end
        end

        pathRunning = false
    end)
end

