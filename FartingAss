local function drawPath(waypoints)
    clearPathLines()
    if #waypoints < 2 then return end

    local positions = {}
    for i = 1, #waypoints do
        table.insert(positions, waypoints[i].Position)
    end

    local smoothPositions = {}
    local subdivisions = 3

    for i = 1, #positions - 1 do
        local p1 = positions[i]
        local p2 = positions[i+1]
        for s = 0, subdivisions - 1 do
            local t = s / subdivisions
            local pos = p1:Lerp(p2, t)
            table.insert(smoothPositions, pos)
        end
    end
    table.insert(smoothPositions, positions[#positions])

    for i = 1, #smoothPositions - 1 do
        local p1 = smoothPositions[i]
        local p2 = smoothPositions[i+1]

        local a1 = Instance.new("Attachment")
        local a2 = Instance.new("Attachment")

        a1.WorldPosition = p1
        a2.WorldPosition = p2

        a1.Parent = PathPart
        a2.Parent = PathPart

        local beam = Instance.new("Beam")
        beam.Attachment0 = a1
        beam.Attachment1 = a2
        beam.Color = ColorSequence.new(Color3.fromRGB(0, 170, 255))
        beam.Width0 = 0.25
        beam.Width1 = 0.25
        beam.FaceCamera = true
        beam.LightInfluence = 0
        beam.TextureSpeed = 0
        beam.Transparency = NumberSequence.new(0)
        beam.Parent = PathFolder
    end
end

