local function addESP(part)
    if highlights[part] then return end

    local h = Instance.new("Highlight")
    h.Adornee = part
    h.FillColor = Color3.fromRGB(255, 200, 0)
    h.OutlineColor = Color3.fromRGB(255, 255, 255)
    h.FillTransparency = 0.5
    h.OutlineTransparency = 0
    h.Parent = part

    highlights[part] = h
end

local function removeAllESP()
    for part, h in pairs(highlights) do
        if h then h:Destroy() end
    end
    highlights = {}

    for _, c in ipairs(connections) do
        c:Disconnect()
    end
    connections = {}
end

local function enableESP()
    local folder = workspace:FindFirstChild("EasterEggs")
    if not folder then return end

    for _, obj in ipairs(folder:GetDescendants()) do
        if obj:IsA("BasePart") then
            addESP(obj)
        end
    end

    table.insert(connections, folder.DescendantAdded:Connect(function(obj)
        if obj:IsA("BasePart") then
            addESP(obj)
        end
    end))
end

